---
const base = import.meta.env.BASE_URL;

interface Props {
  title: string;
  description: string;
  icon: string;
  href?: string;
}

const { title, description, icon, href } = Astro.props;
---

<div class="group bg-white border border-gray-100 rounded-lg p-8 hover:border-gray-200 hover:shadow-sm transition-all">
  <div class="text-2xl mb-4">{icon}</div>
  <h3 class="text-lg font-semibold text-charcoal mb-3">{title}</h3>
  <p class="text-sm text-slate leading-relaxed">{description}</p>
</div>
