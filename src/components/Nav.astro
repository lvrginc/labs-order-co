---
const base = import.meta.env.BASE_URL;
---

<nav class="fixed top-0 w-full z-50 bg-[#0A0A0F]/80 backdrop-blur-md border-b border-white/5">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href={base} class="flex items-center gap-2.5">
      <div class="w-7 h-7 rounded-md bg-gradient-to-br from-emerald-400 to-emerald-600 flex items-center justify-center">
        <span class="text-white text-xs font-bold">A</span>
      </div>
      <span class="text-white font-semibold text-sm tracking-tight">Agentic Labs</span>
    </a>
    <div class="flex items-center gap-8">
      <a href={base} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">Home</a>
      <a href={`${base}blog`} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">Blog</a>
      <a href="https://order.co" target="_blank" rel="noopener" class="text-xs text-gray-600 hover:text-gray-400 transition-colors duration-200 font-mono flex items-center gap-1">
        order.co
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      </a>
    </div>
  </div>
</nav>
