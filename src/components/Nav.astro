---
const base = import.meta.env.BASE_URL;
---

<nav class="fixed top-0 w-full z-50 bg-navy/95 backdrop-blur-sm border-b border-white/5">
  <div class="max-w-content mx-auto px-6 h-16 flex items-center justify-between">
    <a href={base} class="flex items-center gap-3">
      <span class="text-white font-semibold text-lg tracking-tight">Agentic Labs</span>
    </a>
    <div class="flex items-center gap-8">
      <a href={base} class="text-sm text-gray-300 hover:text-white transition-colors">Home</a>
      <a href={`${base}blog`} class="text-sm text-gray-300 hover:text-white transition-colors">Blog</a>
      <a href="https://order.co" target="_blank" rel="noopener" class="text-xs text-gray-500 hover:text-gray-300 transition-colors font-mono">order.co &nearr;</a>
    </div>
  </div>
</nav>
