---
import Base from './Base.astro';

const { frontmatter } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<Base title={`${frontmatter.title} | Agentic Labs`} description={frontmatter.description}>

  <article class="pt-32 pb-24 px-6">
    <div class="max-w-reading mx-auto">
      <a href={`${base}blog`} class="text-sm text-gray-400 hover:text-slate transition-colors">&larr; Back to blog</a>

      <header class="mt-8 mb-12">
        <div class="flex items-center gap-3 mb-4">
          <time class="text-xs font-mono text-gray-400">{frontmatter.date}</time>
          {frontmatter.tags?.map((tag: string) => (
            <span class="text-xs font-mono text-sky bg-sky/10 px-2 py-0.5 rounded">{tag}</span>
          ))}
        </div>
        <h1 class="text-3xl md:text-4xl font-bold text-charcoal leading-tight">{frontmatter.title}</h1>
        {frontmatter.author && (
          <p class="text-sm text-slate mt-4">By {frontmatter.author}</p>
        )}
      </header>

      <div class="prose prose-slate max-w-none prose-headings:font-semibold prose-headings:text-charcoal prose-p:text-slate prose-p:leading-relaxed prose-a:text-order-blue prose-a:no-underline hover:prose-a:underline prose-code:font-mono prose-code:text-sm prose-code:bg-light-gray prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-pre:bg-navy prose-pre:text-gray-300">
        <slot />
      </div>
    </div>
  </article>

</Base>
