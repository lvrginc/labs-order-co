---
import Base from './Base.astro';

const { frontmatter } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<Base title={`${frontmatter.title} | Agentic Labs`} description={frontmatter.description}>

  <article class="pt-32 pb-24 px-6">
    <div class="max-w-[720px] mx-auto">
      <a href={`${base}/blog`} class="text-sm text-gray-500 hover:text-emerald-400 transition-colors flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/></svg>
        Back to blog
      </a>

      <header class="mt-8 mb-12">
        <div class="flex items-center gap-3 mb-4">
          <time class="text-xs font-mono text-gray-600">{frontmatter.date}</time>
          {frontmatter.tags?.map((tag: string) => (
            <span class="text-xs font-mono text-emerald-400/70 bg-emerald-400/5 px-2 py-0.5 rounded">{tag}</span>
          ))}
        </div>
        <h1 class="text-3xl md:text-4xl font-bold text-white leading-tight">{frontmatter.title}</h1>
        {frontmatter.author && (
          <p class="text-sm text-gray-500 mt-4">{frontmatter.author}</p>
        )}
      </header>

      <div class="prose prose-invert max-w-none prose-headings:font-semibold prose-headings:text-white prose-p:text-gray-400 prose-p:leading-relaxed prose-a:text-emerald-400 prose-a:no-underline hover:prose-a:underline prose-strong:text-gray-200 prose-code:font-mono prose-code:text-sm prose-code:bg-white/5 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-pre:bg-[#0D0F14] prose-pre:border prose-pre:border-white/5 prose-pre:text-gray-300 prose-li:text-gray-400">
        <slot />
      </div>
    </div>
  </article>

</Base>
