---
import Base from '../../layouts/Base.astro';

const base = import.meta.env.BASE_URL;

const postFiles = import.meta.glob('./*.md', { eager: true });
const posts = Object.values(postFiles)
  .map((post: any) => ({
    url: post.url,
    frontmatter: post.frontmatter,
  }))
  .sort((a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf());
---

<Base title="Blog | Agentic Labs" description="Technical research, announcements, and insights from Order Agentic Labs.">

  <section class="bg-navy pt-32 pb-16 px-6">
    <div class="max-w-content mx-auto">
      <h1 class="text-3xl md:text-4xl font-bold text-white">Blog</h1>
      <p class="mt-4 text-gray-400 max-w-xl">Technical research, announcements, and insights from the team building agentic procurement infrastructure.</p>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-content mx-auto">
      {posts.length === 0 && (
        <p class="text-slate text-sm">No posts yet. Check back soon.</p>
      )}
      <div class="space-y-8">
        {posts.map((post) => (
          <a href={post.url} class="group block">
            <article class="border-b border-gray-100 pb-8">
              <div class="flex items-center gap-3 mb-3">
                <time class="text-xs font-mono text-gray-400">{post.frontmatter.date}</time>
                {post.frontmatter.tags?.map((tag: string) => (
                  <span class="text-xs font-mono text-sky bg-sky/10 px-2 py-0.5 rounded">{tag}</span>
                ))}
              </div>
              <h2 class="text-xl font-semibold text-charcoal group-hover:text-order-blue transition-colors">{post.frontmatter.title}</h2>
              <p class="text-sm text-slate mt-2 leading-relaxed max-w-2xl">{post.frontmatter.description}</p>
              {post.frontmatter.author && (
                <p class="text-xs text-gray-400 mt-3">By {post.frontmatter.author}</p>
              )}
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>

</Base>
