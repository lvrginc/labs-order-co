---
import Base from '../../layouts/Base.astro';

const base = import.meta.env.BASE_URL;

const postFiles = import.meta.glob('./*.md', { eager: true });
const posts = Object.values(postFiles)
  .map((post: any) => ({
    url: post.url,
    frontmatter: post.frontmatter,
  }))
  .sort((a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf());
---

<Base title="Blog | Agentic Labs" description="Research, technical deep-dives, and updates from Order Agentic Labs.">

  <section class="relative pt-28 pb-12 px-6 overflow-hidden">
    <div class="absolute inset-0 grid-bg"></div>
    <div class="relative max-w-6xl mx-auto">
      <p class="text-emerald-400 font-mono text-xs tracking-wider mb-4">RESEARCH & UPDATES</p>
      <h1 class="text-4xl md:text-5xl font-bold text-white">Blog</h1>
      <p class="mt-4 text-gray-400 max-w-xl">Technical research, architectural decisions, and updates from the team building agentic procurement infrastructure.</p>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-6xl mx-auto">
      {posts.length === 0 && (
        <p class="text-gray-500 text-sm">No posts yet. Check back soon.</p>
      )}
      <div class="space-y-0 divide-y divide-white/5">
        {posts.map((post) => (
          <a href={post.frontmatter.placeholder ? undefined : post.url} class:list={["group block py-8 first:pt-0", post.frontmatter.placeholder ? "cursor-default" : ""]}>
            <article class="flex flex-col md:flex-row md:items-start gap-4 md:gap-8">
              <div class="flex items-center gap-3 md:w-48 shrink-0">
                <time class="text-xs font-mono text-gray-600">{post.frontmatter.date}</time>
                {post.frontmatter.tags?.slice(0, 1).map((tag: string) => (
                  <span class="text-xs font-mono text-emerald-400/60 bg-emerald-400/5 px-2 py-0.5 rounded">{tag}</span>
                ))}
              </div>
              <div class="flex-1">
                <h2 class:list={["text-lg font-semibold transition-colors duration-200", post.frontmatter.placeholder ? "text-gray-500" : "text-white group-hover:text-emerald-400"]}>
                  {post.frontmatter.title}
                  {post.frontmatter.placeholder && <span class="ml-2 text-xs font-mono text-gray-600 font-normal">Coming soon</span>}
                </h2>
                <p class="text-sm text-gray-500 mt-2 leading-relaxed max-w-2xl">{post.frontmatter.description}</p>
              </div>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>

</Base>
