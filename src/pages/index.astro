---
import Base from '../layouts/Base.astro';
import Card from '../components/Card.astro';

const base = import.meta.env.BASE_URL;

const postFiles = import.meta.glob('./blog/*.md', { eager: true });
const posts = Object.values(postFiles)
  .map((post: any) => ({
    url: post.url,
    frontmatter: post.frontmatter,
  }))
  .sort((a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf());
---

<Base title="Agentic Labs | Order">

  <!-- Hero -->
  <section class="bg-navy pt-32 pb-24 px-6">
    <div class="max-w-content mx-auto">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight max-w-3xl">
        Building the agentic infrastructure that transforms how businesses buy.
      </h1>
      <p class="mt-6 text-lg text-gray-400 max-w-2xl leading-relaxed">
        Agentic Labs is Order's AI research and deployment division. We build the agents that run inside Order and deploy into customer environments.
      </p>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="py-24 px-6 bg-light-gray">
    <div class="max-w-content mx-auto">
      <p class="text-xs font-mono text-slate uppercase tracking-wider mb-12">What we build</p>
      <div class="grid md:grid-cols-3 gap-6">
        <Card
          title="Autonomous Ordering"
          description="AI agents that log into vendor portals, compare prices, and place orders without human intervention."
          icon="⚡"
        />
        <Card
          title="Intelligent Approvals"
          description="Policy-aware routing that learns from historical purchasing patterns and organizational rules."
          icon="🔒"
        />
        <Card
          title="Spend Intelligence"
          description="Real-time anomaly detection, vendor performance scoring, and proactive alternative sourcing."
          icon="📊"
        />
      </div>
    </div>
  </section>

  <!-- Thesis -->
  <section class="py-24 px-6">
    <div class="max-w-reading mx-auto">
      <p class="text-xs font-mono text-slate uppercase tracking-wider mb-8">Operating thesis</p>
      <p class="text-xl text-charcoal leading-relaxed">
        Buying complexity does not live in one screen or one approval flow. It lives across vendor coordination, policy enforcement, intake, purchasing, payment, exception handling, and follow-up.
      </p>
      <p class="text-xl text-charcoal leading-relaxed mt-6">
        Traditional software makes those steps visible. Agentic Labs builds infrastructure that executes them.
      </p>
    </div>
  </section>

  <!-- Latest Posts -->
  {posts.length > 0 && (
    <section class="py-24 px-6 bg-light-gray">
      <div class="max-w-content mx-auto">
        <div class="flex items-center justify-between mb-12">
          <p class="text-xs font-mono text-slate uppercase tracking-wider">Latest from the lab</p>
          <a href={`${base}blog`} class="text-sm text-order-blue hover:text-blue-700 transition-colors">All posts &rarr;</a>
        </div>
        <div class="grid md:grid-cols-2 gap-8">
          {posts.slice(0, 4).map((post) => (
            <a href={post.url} class="group block">
              <article class="bg-white border border-gray-100 rounded-lg p-8 hover:border-gray-200 hover:shadow-sm transition-all h-full">
                <div class="flex items-center gap-3 mb-4">
                  <time class="text-xs font-mono text-gray-400">{post.frontmatter.date}</time>
                  {post.frontmatter.tags?.map((tag: string) => (
                    <span class="text-xs font-mono text-sky bg-sky/10 px-2 py-0.5 rounded">{tag}</span>
                  ))}
                </div>
                <h3 class="text-lg font-semibold text-charcoal group-hover:text-order-blue transition-colors">{post.frontmatter.title}</h3>
                <p class="text-sm text-slate mt-3 leading-relaxed">{post.frontmatter.description}</p>
              </article>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</Base>
