---
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL;

const postFiles = import.meta.glob('./blog/*.md', { eager: true });
const posts = Object.values(postFiles)
  .map((post: any) => ({
    url: post.url,
    frontmatter: post.frontmatter,
  }))
  .sort((a, b) => new Date(b.frontmatter.date).valueOf() - new Date(a.frontmatter.date).valueOf());
---

<Base title="Agentic Labs | Order">

  <!-- Hero with grid background and glow orbs -->
  <section class="relative min-h-[90vh] flex items-center overflow-hidden">
    <!-- Background effects -->
    <div class="absolute inset-0 grid-bg"></div>
    <div class="glow-orb w-[500px] h-[500px] bg-emerald-500/20 -top-40 -right-40"></div>
    <div class="glow-orb w-[300px] h-[300px] bg-emerald-600/10 bottom-20 -left-20" style="animation-delay: 3s;"></div>

    <div class="relative max-w-6xl mx-auto px-6 pt-32 pb-24">
      <div class="animate-in">
        <p class="text-emerald-400 font-mono text-sm tracking-wider mb-6">ORDER AGENTIC LABS</p>
      </div>
      <h1 class="animate-in animate-in-delay-1 text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.05] max-w-4xl">
        <span class="text-gray-500">Software automated the process.</span><br/>
        <span class="text-white">What if it could handle the rest<span class="text-emerald-400">?</span></span>
      </h1>
      <p class="animate-in animate-in-delay-2 mt-8 text-lg text-gray-400 max-w-2xl leading-relaxed">
        We research and build autonomous agents that execute real business operations.
      </p>
      <div class="animate-in animate-in-delay-3 mt-12 flex items-center gap-4">
        <a href={`${base}/blog`} class="inline-flex items-center gap-2 bg-emerald-500 hover:bg-emerald-400 text-black font-medium text-sm px-6 py-3 rounded-lg transition-all duration-200">
          Read our research
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Launch Video -->
  <section class="py-20 px-6 relative">
    <div class="max-w-5xl mx-auto">
      <div class="relative aspect-video rounded-2xl overflow-hidden border border-white/10 bg-[#0D0F14] group cursor-pointer">
        <!-- Gradient overlay -->
        <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 via-transparent to-emerald-600/5"></div>
        <!-- Grid pattern inside -->
        <div class="absolute inset-0" style="background-image: linear-gradient(rgba(16,185,129,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(16,185,129,0.03) 1px, transparent 1px); background-size: 40px 40px;"></div>
        <!-- Play button + text -->
        <div class="absolute inset-0 flex flex-col items-center justify-center gap-6">
          <div class="w-20 h-20 rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center group-hover:bg-emerald-500/20 group-hover:border-emerald-500/30 group-hover:scale-105 transition-all duration-300">
            <svg class="w-8 h-8 text-emerald-400 ml-1" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </div>
          <div class="text-center">
            <p class="text-white font-semibold text-lg">Introducing Agentic Labs</p>
            <p class="text-gray-500 text-sm mt-1">Launch video coming soon</p>
          </div>
        </div>
        <!-- Corner accents -->
        <div class="absolute top-4 left-4 w-8 h-8 border-l-2 border-t-2 border-emerald-500/20 rounded-tl-lg"></div>
        <div class="absolute top-4 right-4 w-8 h-8 border-r-2 border-t-2 border-emerald-500/20 rounded-tr-lg"></div>
        <div class="absolute bottom-4 left-4 w-8 h-8 border-l-2 border-b-2 border-emerald-500/20 rounded-bl-lg"></div>
        <div class="absolute bottom-4 right-4 w-8 h-8 border-r-2 border-b-2 border-emerald-500/20 rounded-br-lg"></div>
      </div>
    </div>
  </section>

  <!-- Problem Space -->
  <section class="py-32 px-6 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0A0A0F] via-[#0D0F14] to-[#0A0A0F]"></div>
    <div class="relative max-w-6xl mx-auto">
      <p class="text-emerald-400 font-mono text-xs tracking-wider mb-4">THE GAP</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white max-w-3xl leading-tight mb-16">
        Procurement software automated the workflow. 
        <span class="text-gray-500">But someone still has to do the work between the workflows.</span>
      </h2>

      <div class="grid md:grid-cols-3 gap-px bg-white/5 rounded-xl overflow-hidden">
        <div class="bg-[#0D0F14] p-8 group hover:bg-[#0F1218] transition-colors duration-300">
          <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center mb-6 group-hover:bg-emerald-500/20 transition-colors">
            <span class="text-emerald-400 text-lg">01</span>
          </div>
          <h3 class="text-white font-semibold mb-3">Vendor coordination</h3>
          <p class="text-gray-500 text-sm leading-relaxed">Logging into portals, comparing prices, chasing quotes, placing orders. Automated within each system, but someone still navigates between them.</p>
        </div>
        <div class="bg-[#0D0F14] p-8 group hover:bg-[#0F1218] transition-colors duration-300">
          <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center mb-6 group-hover:bg-emerald-500/20 transition-colors">
            <span class="text-emerald-400 text-lg">02</span>
          </div>
          <h3 class="text-white font-semibold mb-3">Policy judgment</h3>
          <p class="text-gray-500 text-sm leading-relaxed">Rules get codified. But the gray areas, the exceptions, the "call finance and ask" moments still need a person making a judgment call.</p>
        </div>
        <div class="bg-[#0D0F14] p-8 group hover:bg-[#0F1218] transition-colors duration-300">
          <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center mb-6 group-hover:bg-emerald-500/20 transition-colors">
            <span class="text-emerald-400 text-lg">03</span>
          </div>
          <h3 class="text-white font-semibold mb-3">Follow-through</h3>
          <p class="text-gray-500 text-sm leading-relaxed">The vendor shipped late. The invoice doesn't match. The budget moved. Every transaction has a tail of follow-up that falls on someone's plate.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Research Areas -->
  <section class="py-32 px-6 relative border-t border-white/5">
    <div class="max-w-6xl mx-auto">
      <p class="text-emerald-400 font-mono text-xs tracking-wider mb-4">RESEARCH AREAS</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white max-w-2xl leading-tight mb-16">
        We work on the parts that still require a person.
      </h2>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="border border-white/5 rounded-xl p-8 hover:border-emerald-500/20 transition-all duration-300 group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
            <p class="text-emerald-400 font-mono text-xs">ACTIVE</p>
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">Task completion across systems</h3>
          <p class="text-gray-500 text-sm leading-relaxed">Agents that navigate vendor portals, compare options within policy constraints, and carry transactions through to completion, so your team focuses on decisions that matter.</p>
        </div>
        <div class="border border-white/5 rounded-xl p-8 hover:border-emerald-500/20 transition-all duration-300 group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
            <p class="text-emerald-400 font-mono text-xs">ACTIVE</p>
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">Adaptive policy understanding</h3>
          <p class="text-gray-500 text-sm leading-relaxed">Systems that learn how your organization actually makes purchasing decisions, including the unwritten rules, and apply that judgment consistently.</p>
        </div>
        <div class="border border-white/5 rounded-xl p-8 hover:border-emerald-500/20 transition-all duration-300 group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
            <p class="text-emerald-400 font-mono text-xs">ACTIVE</p>
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">Confidence-aware escalation</h3>
          <p class="text-gray-500 text-sm leading-relaxed">Agents that know when to hand off. When the situation needs human judgment, they escalate with full context instead of guessing or stalling.</p>
        </div>
        <div class="border border-white/5 rounded-xl p-8 hover:border-emerald-500/20 transition-all duration-300 group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-2 h-2 rounded-full bg-yellow-400"></div>
            <p class="text-yellow-400 font-mono text-xs">EXPLORING</p>
          </div>
          <h3 class="text-xl font-semibold text-white mb-3">Cross-system orchestration</h3>
          <p class="text-gray-500 text-sm leading-relaxed">Coordinating agent actions across ERP, procurement, payment, and vendor systems with transactional integrity and full audit trails.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Thesis / Belief -->
  <section class="py-32 px-6 relative border-t border-white/5">
    <div class="absolute inset-0 bg-gradient-to-b from-[#0A0A0F] via-[#080B10] to-[#0A0A0F]"></div>
    <div class="relative max-w-3xl mx-auto text-center">
      <p class="text-emerald-400 font-mono text-xs tracking-wider mb-8">OUR VISION</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white leading-tight">
        Agentic B2B commerce that adapts to the customer.
      </h2>
      <p class="mt-6 text-lg text-gray-400 leading-relaxed max-w-2xl mx-auto">
        To accelerate Order's mission of simplifying business buying by building the agentic infrastructure that transforms both our internal operations and our customer workflows.
      </p>
    </div>
  </section>

  <!-- Latest from the Lab -->
  {posts.length > 0 && (
    <section class="py-32 px-6 border-t border-white/5">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-center justify-between mb-12">
          <div>
            <p class="text-emerald-400 font-mono text-xs tracking-wider mb-2">FROM THE LAB</p>
            <h2 class="text-2xl font-bold text-white">Latest research and updates</h2>
          </div>
          <a href={`${base}/blog`} class="text-sm text-gray-400 hover:text-emerald-400 transition-colors flex items-center gap-2">
            All posts
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.slice(0, 6).map((post) => (
            <a href={post.url} class="group block">
              <article class="border border-white/5 rounded-xl p-6 hover:border-emerald-500/20 transition-all duration-300 h-full bg-[#0D0F14]">
                <div class="flex items-center gap-2 mb-4">
                  <time class="text-xs font-mono text-gray-600">{post.frontmatter.date}</time>
                  {post.frontmatter.tags?.slice(0, 1).map((tag: string) => (
                    <span class="text-xs font-mono text-emerald-400/70 bg-emerald-400/5 px-2 py-0.5 rounded">{tag}</span>
                  ))}
                </div>
                <h3 class="text-base font-semibold text-white group-hover:text-emerald-400 transition-colors duration-200 leading-snug">{post.frontmatter.title}</h3>
                <p class="text-xs text-gray-500 mt-3 leading-relaxed line-clamp-2">{post.frontmatter.description}</p>
              </article>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</Base>
